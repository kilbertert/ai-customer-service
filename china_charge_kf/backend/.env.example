## FastAPI
# Comma-separated origins for CORS, e.g. "http://localhost:5173"
APP_CORS_ORIGINS=http://localhost:5173

## Dify (current — M2 frozen contract)
# Dify API base — cloud / 阿里云国服统一域名,自动路由
DIFY_API_BASE=https://api.dify.ai/v1

# v1 workflow API key — used by legacy blocking /api/chat (multipart audio/image)
DIFY_API_KEY=app-your-v1-key-here

# v2 workflow API key — used by M4 streaming /api/chat/stream + /api/files/upload
# NOTE: v1 / v2 是两个独立的 Dify app,各自有独立 API key;不能复用
DIFY_V2_API_KEY=app-your-v2-key-here

# Workflow input variable names — must match Dify "开始" node schema
DIFY_INPUT_TEXT=input_text
DIFY_INPUT_IMAGE=input_img_id
DIFY_INPUT_AUDIO=input_audio_id
DIFY_INPUT_LANGUAGE=language

# Dify end-user identifier (Dify 强制要求,用于会话追踪)
DIFY_END_USER=h5-frontend-user

# Workflow output variable name — 结束节点"直接回复"里设置的变量名
DIFY_OUTPUT_TEXT=output

## Coze (legacy — kept for backward compatibility, app_coze/ 仍可独立运行)
# API base. For mainland China: https://api.coze.cn
# For global: https://api.coze.com (if your account uses global endpoint)
COZE_API_BASE=https://api.coze.cn

# Personal Access Token (PAT)
COZE_API_TOKEN=pat_qHgONbMj5fLYnU7OJqvqdQZd4Yd9KnpCcFFf1T7k0PxFilO2m59Y398kV3FoUQ9I

# Your workflow id (string)
COZE_WORKFLOW_ID=7615498037791588402

# Workflow parameter names (match your Coze workflow input schema)
# Example: text param is "text", image file id param is "image_id"
COZE_PARAM_TEXT=input_text
COZE_PARAM_IMAGE_ID=input_img_id
COZE_PARAM_AUDIO_ID=input_audio_id
COZE_PARAM_LANGUAGE=language
