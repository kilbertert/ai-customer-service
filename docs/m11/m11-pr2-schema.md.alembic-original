## 2. Alembic 迁移脚本

**文件路径**:`backend/alembic/versions/2026_06_17_xxxx_add_dify_provisioning.py`

```python
"""add dify provisioning fields

Revision ID: 2026_06_17_xxxx
Revises: <previous>
Create Date: 2026-06-17
"""

from alembic import op
import sqlalchemy as sa
from sqlalchemy.dialects.postgresql import UUID


revision = "2026_06_17_xxxx"
down_revision = "<previous>"
branch_labels = None
depends_on = None


def upgrade() -> None:
    # 1. workspaces 表加 6 列
    op.add_column("workspaces", sa.Column("dify_tenant_id", sa.String(36), nullable=True))
    op.add_column("workspaces", sa.Column("dify_account_id", sa.String(36), nullable=True))
    op.add_column("workspaces", sa.Column(
        "dify_provisioning_status", sa.String(20), nullable=False, server_default="pending"))
    op.add_column("workspaces", sa.Column(
        "dify_provisioning_attempts", sa.Integer, nullable=False, server_default="0"))
    op.add_column("workspaces", sa.Column("dify_provisioning_last_error", sa.Text, nullable=True))
    op.add_column("workspaces", sa.Column("signup_idempotency_key", sa.String(36), nullable=True))

    # 2. 索引
    op.create_index("idx_workspaces_dify_tenant_id", "workspaces", ["dify_tenant_id"], unique=False)
    op.create_index(
        "idx_workspaces_dify_provisioning_status",
        "workspaces",
        ["dify_provisioning_status"],
        unique=False,
        postgresql_where=sa.text("dify_provisioning_status IN ('failed', 'provisioning')"),
    )

    # 3. signup_idempotency_key UNIQUE 约束
    op.create_unique_constraint(
        "uq_workspaces_signup_idempotency_key", "workspaces", ["signup_idempotency_key"])

    # 4. audit_logs 新表
    op.create_table(
        "audit_logs",
        sa.Column("id", sa.BigInteger, primary_key=True, autoincrement=True),
        sa.Column("tenant_id", sa.String(36), nullable=False),
        sa.Column("actor_user_id", sa.Integer, nullable=False),
        sa.Column("action", sa.String(64), nullable=False),
        sa.Column("dify_request_id", sa.String(36), nullable=True),
        sa.Column("correlation_id", sa.String(36), nullable=False),
        sa.Column("status", sa.String(20), nullable=False),
        sa.Column("error_detail", sa.Text, nullable=True),
        sa.Column("created_at", sa.TIMESTAMP, nullable=False,
                  server_default=sa.text("CURRENT_TIMESTAMP")),
    )

    # 5. audit_logs 索引
    op.create_index("idx_audit_logs_tenant_id_created_at", "audit_logs",
                    ["tenant_id", "created_at"], unique=False)
    op.create_index("idx_audit_logs_correlation_id", "audit_logs",
                    ["correlation_id"], unique=False)


def downgrade() -> None:
    op.drop_index("idx_audit_logs_correlation_id", "audit_logs")
    op.drop_index("idx_audit_logs_tenant_id_created_at", "audit_logs")
    op.drop_table("audit_logs")

    op.drop_constraint("uq_workspaces_signup_idempotency_key", "workspaces")
    op.drop_index("idx_workspaces_dify_provisioning_status", "workspaces")
    op.drop_index("idx_workspaces_dify_tenant_id", "workspaces")
    op.drop_column("workspaces", "signup_idempotency_key")
    op.drop_column("workspaces", "dify_provisioning_last_error")
    op.drop_column("workspaces", "dify_provisioning_attempts")
    op.drop_column("workspaces", "dify_provisioning_status")
    op.drop_column("workspaces", "dify_account_id")
    op.drop_column("workspaces", "dify_tenant_id")
